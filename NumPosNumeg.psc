//Problema
//Un programa que solicite al usuario un valor numérico
//Mostrar en pantalla si es positivo o negativo
Algoritmo NumPosNumeg
	//Variable
	Definir num Como Entero
	Escribir "Dame un número entero: "
	Leer num
	
	//Condición
	Si num >= 0 Entonces
		Escribir "Soy un número POSITIVO"
	SiNo
		Escribir "Soy un número NEGATIVO"
	FinSi
FinAlgoritmo
